generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Project {
  id        String   @id @default(cuid())
  name      String
  vision    String   @db.Text
  goals     String[]
  version   String   @default("1.0.0")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  architecture     ArchitectureNode[]
  memory           MemoryEntry[]
  proposals        Proposal[]
  branches         DecisionBranch[]
  tasks            ImplementationTask[]
  agentLogs        AgentLog[]
  driftAlerts      DriftAlert[]
}

model ArchitectureNode {
  id           String   @id @default(cuid())
  projectId    String
  name         String
  type         String
  description  String   @db.Text
  dependencies String[]
  project      Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model MemoryEntry {
  id         String   @id @default(cuid())
  projectId  String
  title      String
  content    String   @db.Text
  source     String
  decisionId String?
  createdAt  DateTime @default(now())
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model Proposal {
  id               String   @id @default(cuid())
  projectId        String
  title            String
  description      String   @db.Text
  authorId         String
  authorName       String
  status           String   @default("draft")
  branchId         String?
  contextJson      Json?
  impactJson       Json?
  reviewJson       Json?
  votesJson        Json?
  managerApproved  Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  project          Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model DecisionBranch {
  id             String   @id @default(cuid())
  projectId      String
  name           String
  proposalId     String
  parentBranchId String?
  version        String
  merged         Boolean  @default(false)
  mergedAt       DateTime?
  snapshotJson   Json
  createdAt      DateTime @default(now())
  project        Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model ImplementationTask {
  id                 String   @id @default(cuid())
  projectId          String
  title              String
  description        String   @db.Text
  status             String   @default("pending")
  branchId           String
  proposalId         String?
  affectedComponents String[]
  assignee           String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  project            Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model AgentLog {
  id         String   @id @default(cuid())
  projectId  String
  agent      String
  action     String
  input      String   @db.Text
  output     String   @db.Text
  proposalId String?
  timestamp  DateTime @default(now())
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model DriftAlert {
  id             String   @id @default(cuid())
  projectId      String
  severity       String
  source         String
  description    String   @db.Text
  recommendation String   @db.Text
  detectedAt     DateTime @default(now())
  project        Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

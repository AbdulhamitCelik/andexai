# MongoDB Atlas (primary)
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/andexai?retryWrites=true&w=majority&appName=Cluster0

# Optional local fallback (Podman/Docker) when Atlas is unreachable
MONGODB_URI_FALLBACK=mongodb://127.0.0.1:27017/andexai

# Windows TLS: npm scripts use `node --use-system-ca` so Atlas SSL certs verify correctly.

# Optional — PostgreSQL + Prisma (legacy scaffold; app uses MongoDB)
DATABASE_URL="postgresql://user:password@localhost:5432/andex_ai"

# LLM providers (optional — any ONE key below enables Ask the Project Brain + AI review)
# Supported: Groq, Cerebras, OpenRouter, NVIDIA NIM, Mistral, SambaNova, Cohere

# OpenRouter — OpenAI-compatible gateway (https://openrouter.ai/keys)
OPENROUTER_API_KEY=""
OPENROUTER_BASE_URL="https://openrouter.ai/api/v1"

# NVIDIA NIM — OpenAI-compatible (https://build.nvidia.com)
NVIDIA_API_KEY=""
NVIDIA_BASE_URL="https://integrate.api.nvidia.com/v1"

# Optional headers OpenRouter uses for attribution
OPENROUTER_SITE_URL=""
OPENROUTER_SITE_NAME=""

# --- Free-tier providers (all OpenAI-compatible; sign up, no card needed) ---

# Groq — fast inference (https://console.groq.com/keys)
GROQ_API_KEY=""
GROQ_BASE_URL="https://api.groq.com/openai/v1"

# Cerebras — fast inference (https://cloud.cerebras.ai)
CEREBRAS_API_KEY=""
CEREBRAS_BASE_URL="https://api.cerebras.ai/v1"

# Mistral AI — EU provider (https://console.mistral.ai/api-keys)
MISTRAL_API_KEY=""
MISTRAL_BASE_URL="https://api.mistral.ai/v1"

# SambaNova Cloud — fast Llama inference (https://cloud.sambanova.ai)
SAMBANOVA_API_KEY=""
SAMBANOVA_BASE_URL="https://api.sambanova.ai/v1"

# Cohere — OpenAI-compatible endpoint (https://dashboard.cohere.com/api-keys)
COHERE_API_KEY=""
COHERE_BASE_URL="https://api.cohere.ai/compatibility/v1"

# Integrations (future)
GITHUB_TOKEN=""
SLACK_BOT_TOKEN=""

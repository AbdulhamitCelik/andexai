{
  "name": "andex-ai",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node --use-system-ca ./node_modules/next/dist/bin/next dev",
    "build": "node --use-system-ca ./node_modules/next/dist/bin/next build",
    "start": "node --use-system-ca ./node_modules/next/dist/bin/next start",
    "lint": "next lint",
    "db:init": "curl -X POST http://localhost:3000/api/db/init",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "test:llm": "node --use-system-ca --env-file=.env.local scripts/test-llm.mjs",
    "test:mongo": "node --use-system-ca --env-file=.env.local scripts/test-mongo.mjs",
    "test:mongo:diag": "node --use-system-ca --env-file=.env.local scripts/test-mongo-diagnose.mjs",
    "test:scenarios": "tsx scripts/test-scenarios.ts"
  },
  "dependencies": {
    "@prisma/client": "6.5.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.475.0",
    "mongoose": "^9.7.3",
    "next": "^15.2.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^3.0.1",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/uuid": "^10.0.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.20.0",
    "eslint-config-next": "^15.2.0",
    "postcss": "^8.5.0",
    "prisma": "6.5.0",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
